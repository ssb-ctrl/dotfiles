#!/usr/bin/env sh

# Extract values from /proc/meminfo OR you can take values from $(free) command
TOTAL_KB=$(rg MemTotal /proc/meminfo | awk '{print $2}')
AVAIL_KB=$(rg MemAvailable /proc/meminfo | awk '{print $2}')

USED_KB=$((TOTAL_KB - AVAIL_KB))
RAM_USAGE=$((100 * USED_KB / TOTAL_KB))

STATE_FILE="/tmp/memory_state"

if [ "$RAM_USAGE" -le "55" ]; then
	rm "$STATE_FILE"
	exit 0
fi

LAST=0
if [ -f "$STATE_FILE" ]; then
	LAST=$(cat "$STATE_FILE")
fi

if [ "$RAM_USAGE" -gt "55" ] && [ "$RAM_USAGE" -le "75" ] && [ "$LAST" -ne "1" ]; then
	notify-send "Memory" "$RAM_USAGE% memory used" -u normal -i ~/Pictures/icons/ram.svg
	echo 1 > "$STATE_FILE"
	exit 0
fi

if [ "$RAM_USAGE" -ge "75" ] && [ "$LAST" -ne 2 ]; then
	notify-send "Memory" "$RAM_USAGE% memory used" -u critical -i ~/Pictures/icons/ram.svg
	echo 2 > "$STATE_FILE"
	exit 0
fi

