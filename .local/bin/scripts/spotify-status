#!/usr/bin/env sh

status=$(playerctl -p spotify status 2>/dev/null)
MAX=28
ARTIST=$(playerctl -p spotify metadata xesam:artist)
TITLE=$(playerctl -p spotify metadata xesam:title)

if [[ "$status" == "Playing" ]]; then
  SONG=$(playerctl metadata -p spotify --format "{{title}} - {{artist}}")
    if [[ ${#SONG} -gt $MAX ]]; then
        SONG="${SONG:0:$MAX}..."
    fi
    echo "{ \"text\": \"у°“‡ $SONG\", \
          \"tooltip\": \"у°“‡ Spotify currently playing\nу°ќљ Title у°Ѓ” $TITLE\nоґѓ Artist у°Ѓ” $ARTIST\", \
          \"class\": \"playing\" }"

elif [[ "$status" == "Paused" ]]; then
    echo '{"text": "п†ј пЃЊ", "tooltip": "п†ј Spotify currently paused", "class": "paused"}' 

else
    echo '{"text": "п†ј в „в „в „", "tooltip": "п†ј Spotify instance not running", "class": "idle"}' 
fi
