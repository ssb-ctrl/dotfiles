#!/usr/bin/env sh

MUTED=$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -o MUTED)

if [[ "$MUTED" == "MUTED" ]]; then
  echo "{\"text\":\"箚뜭\", \"tooltip\":\"Default Source/Input 箚걫 muted\", \"class\":\"muted\"}"
else
  echo "{\"text\":\"箚뜫\", \"tooltip\":\"Default Source/Input 箚걫 active\", \"class\":\"active\"}"
fi
