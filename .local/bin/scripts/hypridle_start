#!/usr/bin/env sh

if pidof hypridle >/dev/null; then
	notify-send Hypridle "Service already running" -a Hypridle -u low -i ~/Pictures/icons/hyprland.png  -h string:x-canonical-private-synchronous:Hypridle
else
	hypridle & disown
	sleep 0.3s
	notify-send Hypridle "Service started" -a Hypridle  -u low -i ~/Pictures/icons/hyprland.png -h string:x-canonical-private-synchronous:Hypridle
fi

