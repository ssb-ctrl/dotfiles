#!/usr/bin/env sh

# Define the volume limit
MAX_VOLUME=150

# Get the current volume level using either pactl wpctl or pamixer
CURRENT_VOLUME=$(pactl get-sink-volume @DEFAULT_SINK@ | grep -oP '\d+%' | tail -n 1 | tr -d '%')

# Check if the volume is below the maximum limit
if (( CURRENT_VOLUME < MAX_VOLUME )); then
  pactl set-sink-volume @DEFAULT_SINK@ +5%
	exit 0
fi
