max-history=8
sort=-time
layer=overlay

font=CaskaydiaCove Nerd Font 9
background-color=#222436FF
text-color=#c0caf5ff
border-color=#0eb2dcff
border-size=1
width=310
height=200

#top, left and right, bottom
padding=8
margin=6
outer-margin=10

icons=1
max-icon-size=64
text-alignment=left
default-timeout=3200
ignore-timeout=1
max-visible=5

#on-button-middle=exec makoctl menu -n "$id" dmenu -p 'Select action:'
on-button-middle=none
on-button-left=invoke-default-action
on-button-right=dismiss
on-touch=none
on-notify=exec mpv /usr/share/sounds/freedesktop/stereo/message.oga

[urgency="low"]
default-timeout=1000
ignore-timeout=1

[urgency="normal"]
default-timeout=2000
ignore-timeout=1

[urgency="critical"]
default-timeout=0
ignore-timeout=1
border-color=#ff0000ff

#[app-name="com.dec05eba.gpu_screen_recorder"]
#icon-path=/home/satya/Pictures/icons/app-icons/gpu-screen-recorder/Gpu Screen Recorder.png
#on-notify=none

[app-name="powerprofile"]
#on-notify=none
#anchor=bottom-center

[app-name="animation_toggle"]
on-notify=none

[app-name="capslock"]
on-notify=none

[app-name="conservation"]
#on-notify=none

[app-name="Hypridle"]
on-notify=none

[app-name="Hyprpaper"]
on-notify=none

[app-name="Hyprsunset"]
on-notify=none

[app-name="Waybar"]
on-notify=none
