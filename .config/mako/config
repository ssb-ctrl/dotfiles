max-history=8
sort=-time
layer=overlay

font=CaskaydiaCove Nerd Font 9
background-color=#212337FF
text-color=#c0caf5ff
#border-color=#97e7fd
border-color=#82aaff
border-size=2
#border-radius=6
width=275
height=200

#top, left and right, bottom
padding=8
margin=6
outer-margin=10

icons=1
max-icon-size=128
text-alignment=left
default-timeout=3200
ignore-timeout=1
max-visible=5

#on-button-middle=exec makoctl menu -n "$id" dmenu -p 'Select action:'
on-button-middle=none
on-button-left=invoke-default-action
on-button-right=dismiss
on-touch=none
on-notify=exec mpv /home/$USER/.config/mako/system_sounds/notify8.mp3

[urgency="low"]
default-timeout=1250

[urgency="normal"]
default-timeout=2500

[urgency="critical"]
default-timeout=4500
border-color=#ff7972ff

[app-name="powerprofile"]
#on-notify=none
#anchor=bottom-center

[app-name="animation_toggle"]
#on-notify=none

[app-name="capslock"]
on-notify=none
anchor=center
margin=500
default-timeout=800
ignore-timeout=1

[app-name="conservation"]
#on-notify=none

[app-name="Hypridle"]
#on-notify=none

[app-name="Hyprpaper"]
on-notify=none

[app-name="Hyprsunset"]
#on-notify=none

[app-name="Waybar"]
on-notify=none
